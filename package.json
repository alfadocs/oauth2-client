{
  "name": "@alfadocs/auth",
  "version": "0.3.0",
  "description": "Bridgeable Alfadocs auth core with infrastructure adapters",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./supabase-bridge": {
      "types": "./dist/supabase-bridge/index.d.ts",
      "import": "./dist/supabase-bridge/index.js",
      "default": "./dist/supabase-bridge/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-migrations.mjs",
    "local:test-app": "npm run build && node tests/local-app/server.mjs",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "oauth2",
    "alfadocs",
    "auth",
    "bridge",
    "supabase"
  ],
  "author": "AlfaDocs",
  "license": "MIT",
  "devDependencies": {
    "dotenv": "^17.4.1",
    "typescript": "^5.6.3",
    "undici": "^8.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "jose": "^6.2.2",
    "postgres": "^3.4.9"
  }
}
