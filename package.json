{
  "name": "@alfadocs/oauth2-client",
  "version": "0.3.0",
  "description": "Backend-first Alfadocs auth library and Supabase identity bridge",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./supabase": {
      "types": "./dist/supabase/index.d.ts",
      "import": "./dist/supabase/index.js",
      "default": "./dist/supabase/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build"
  },
  "keywords": [
    "oauth2",
    "pkce",
    "alfadocs",
    "supabase",
    "edge-functions",
    "deno",
    "auth"
  ],
  "author": "AlfaDocs",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
